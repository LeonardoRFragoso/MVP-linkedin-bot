# ============================================
# LinkedIn Bot White Label - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/linkedin_bot
# For SQLite (development only):
# DATABASE_URL=sqlite:///./data/linkedin_bot.db

# ============================================
# Security Keys
# ============================================
# Secret key for JWT tokens and session management (min 32 chars)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Encryption key for sensitive data (LinkedIn credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================
# AI Provider Configuration
# ============================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# Default AI provider: openai, deepseek, gemini
DEFAULT_AI_PROVIDER=openai

# ============================================
# Tenant Configuration
# ============================================
# Default tenant for single-tenant mode
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_SLUG=default

# Enable multi-tenant mode
MULTI_TENANT_ENABLED=false

# ============================================
# Application Settings
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (never enable in production)
DEBUG=true

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# ============================================
# External Services (Optional)
# ============================================
# Stripe for billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Webhook URL for notifications
WEBHOOK_URL=

# ============================================
# Rate Limiting
# ============================================
# Max applications per day per user
MAX_APPLICATIONS_PER_DAY=100

# Max API requests per minute
API_RATE_LIMIT=60
